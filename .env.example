# Copia este archivo a .env para desarrollo local (no lo subas al repositorio).
# En Railway: pestaña "Variables" del servicio, agrega las mismas claves.

# Puerto en el que escucha el servidor. Railway lo asigna automaticamente en produccion;
# en local, si lo dejas vacio, usa 3000.
PORT=3000

# Requerida para el asistente IA (Gemini). Crea una key gratis (sin tarjeta) en
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Opcional. Cambia el modelo de Gemini sin tocar codigo. Por defecto usa gemini-3.1-flash-lite
# (GA y gratuito). Evita gemini-2.5-flash: desde el 9 de julio de 2026 devuelve 404 en
# proyectos/keys nuevos aunque su retiro oficial es recien en octubre.
GEMINI_MODEL=gemini-3.1-flash-lite

# Opcional. Limite de preguntas al chat IA por IP, para no agotar la cuota gratuita compartida.
CHAT_RATE_LIMIT_WINDOW_MS=60000
CHAT_RATE_LIMIT_MAX_REQUESTS=8
